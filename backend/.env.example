# Server Port
PORT=5000

# Node Environment
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Use a full connection string (e.g. from Neon, Supabase, or Render)
DATABASE_URL=postgresql://postgres:password@localhost:5432/vitto_db

# SSL Connection to PostgreSQL (Set to 'true' if connecting to a cloud DB that requires SSL)
PGSSL=false

# Production frontend URL allowed by CORS
# Example: https://vitto.vercel.app
FRONTEND_URL=http://localhost:5173

# JSON Web Token Secret (Change to a long secure string in production)
JWT_SECRET=vitto_loan_portal_secure_secret_key_change_me
